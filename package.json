{
  "name": "@modulify/git-toolkit",
  "type": "module",
  "version": "0.0.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modulify/git-toolkit.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs",
      "default": "./dist/*.mjs"
    },
    "./dist/*": "./dist/*",
    "./types/*": "./types/*"
  },
  "files": [
    "dist",
    "types",
    "LICENSE.md",
    "README.md"
  ],
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "git": [
        "./dist/git.d.ts"
      ],
      "shell": [
        "./dist/shell.d.ts"
      ],
      "stream": [
        "./dist/stream.d.ts"
      ]
    }
  },
  "peerDependencies": {
    "@types/node": ">=20"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.15.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.41",
    "@vitest/coverage-istanbul": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.4",
    "unplugin-dts": "^1.0.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "vite build",
    "eslint": "eslint src tests types",
    "test": "vitest run --coverage"
  },
  "author": {
    "name": "modulify",
    "email": "https://github.com/modulify"
  },
  "contributors": [
    {
      "name": "Zaitsev Kirill",
      "email": "zaytsev.cmath10@gmail.com"
    },
    {
      "name": "conventional-changelog team",
      "url": "https://github.com/conventional-changelog"
    }
  ],
  "keywords": [
    "git"
  ],
  "publishConfig": {
    "access": "public"
  }
}
